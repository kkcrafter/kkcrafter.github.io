---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  lang?: string;
  type?: string;
  pubDate?: Date;
  updatedDate?: Date;
}

const { title, description, image, lang = 'en', type, pubDate, updatedDate } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead title={title} description={description} image={image} lang={lang} type={type} pubDate={pubDate} updatedDate={updatedDate} />
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
