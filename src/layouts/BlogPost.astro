---
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getLangFromUrl, t, type Lang } from '../i18n/ui';
import { getTagLabel } from '../i18n/tags';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  lang: string;
  image?: { src: string; alt: string };
}

const { title, description, pubDate, updatedDate, tags, lang: postLang, image } = Astro.props;
const lang = (postLang || getLangFromUrl(Astro.url)) as Lang;
---

<BaseLayout title={`${title} | ${t(lang, 'site.title')}`} description={description} lang={lang}>
  <article class="post">
    <header class="post__header">
      <h1>{title}</h1>
      <div class="post__meta">
        <span>
          {t(lang, 'blog.publishedOn')}{' '}
          <FormattedDate date={pubDate} lang={lang} />
        </span>
        {updatedDate && (
          <span>
            {t(lang, 'blog.updatedOn')}{' '}
            <FormattedDate date={updatedDate} lang={lang} />
          </span>
        )}
      </div>
      {tags.length > 0 && (
        <div class="post__tags">
          {tags.map((tag) => (
            <a href={`/${lang}/blog/tag/${tag}/`} class="tag">
              {getTagLabel(tag, lang)}
            </a>
          ))}
        </div>
      )}
    </header>

    <div class="post__content">
      <slot />
    </div>

    <footer class="post__footer">
      <a href={`/${lang}/blog/`}>&larr; {t(lang, 'blog.backToList')}</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .post__header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .post__header h1 {
    margin-bottom: 0.75rem;
  }

  .post__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .post__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .tag {
    display: inline-block;
    font-size: 0.75rem;
    padding: 0.2em 0.6em;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-muted);
    text-decoration: none;
  }

  .tag:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .post__content {
    margin-bottom: 3rem;
  }

  .post__footer {
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.9rem;
  }
</style>
