---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/ui';

const lang = 'zh';
---

<BaseLayout
  title={`${t(lang, 'about.meta.title')} | ${t(lang, 'site.title')}`}
  description={t(lang, 'about.meta.description')}
  lang={lang}
>
  <article class="about">
    <h1>{t(lang, 'about.meta.title')}</h1>

    <section class="about__bio">
      <p>{t(lang, 'home.about.p1')}</p>
      <p>{t(lang, 'home.about.p2')}</p>
    </section>

    <section class="about__skills">
      <h2>{t(lang, 'about.skills.title')}</h2>
      <ul class="skills-list">
        <li>
          <strong>{t(lang, 'about.skills.esg')}</strong>
          <span>{t(lang, 'about.skills.esg.desc')}</span>
        </li>
        <li>
          <strong>{t(lang, 'about.skills.it')}</strong>
          <span>{t(lang, 'about.skills.it.desc')}</span>
        </li>
        <li>
          <strong>{t(lang, 'about.skills.lang')}</strong>
          <span>{t(lang, 'about.skills.lang.desc')}</span>
        </li>
      </ul>
    </section>

    <section class="about__connect">
      <h2>{t(lang, 'about.connect')}</h2>
      <div class="connect-links">
        <a href="https://github.com/kkcrafter" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://www.linkedin.com/in/kmkwokkelvin/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .about h1 {
    margin-bottom: 1.5rem;
  }

  .about__bio {
    margin-bottom: 2.5rem;
    line-height: 1.8;
  }

  .about__bio p {
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .about__skills {
    margin-bottom: 2.5rem;
  }

  .about__skills h2 {
    font-size: 1.35rem;
    margin-bottom: 1rem;
  }

  .skills-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .skills-list li {
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background-color: var(--color-surface, transparent);
  }

  .skills-list strong {
    display: block;
    font-size: 1rem;
    margin-bottom: 0.25rem;
    color: var(--color-text);
  }

  .skills-list span {
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .about__connect {
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .about__connect h2 {
    font-size: 1.35rem;
    margin-bottom: 1rem;
  }

  .connect-links {
    display: flex;
    gap: 1rem;
  }

  .connect-links a {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    text-decoration: none;
    color: var(--color-text);
    font-size: 0.9rem;
    transition: border-color 0.2s, color 0.2s;
  }

  .connect-links a:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
</style>
