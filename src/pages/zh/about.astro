---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getEntry, render } from "astro:content";

const lang = "zh";
const entry = await getEntry("pages", `${lang}/about`);
const { Content } = await render(entry!);
const { title, description } = entry!.data;
---

<BaseLayout title={title} description={description} lang={lang}>
  <article class="about-page">
    <Content />
  </article>
</BaseLayout>

<style>
  .about-page {
    line-height: 1.8;
  }

  /* Page title (h1) */
  .about-page :global(h1) {
    font-size: 2rem;
    margin-bottom: 1.5rem;
    color: var(--color-text);
  }

  /* Bio paragraphs */
  .about-page :global(p) {
    margin-bottom: 1rem;
    color: var(--color-muted);
  }

  /* Section headings (h2) — e.g. "Skills & Interests", "Connect" */
  .about-page :global(h2) {
    font-size: 1.35rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-text);
  }

  /* Skill category headings (h3) — card header */
  .about-page :global(h3) {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    padding: 1rem 1.25rem 0.25rem;
    background-color: var(--color-surface, transparent);
    border: 1px solid var(--color-border);
    border-bottom: none;
    border-radius: 8px 8px 0 0;
  }

  /* Bullet list after h3 — card body */
  .about-page :global(h3 + ul) {
    list-style: none;
    padding: 0.25rem 1.25rem 1rem;
    margin: 0 0 1rem;
    background-color: var(--color-surface, transparent);
    border: 1px solid var(--color-border);
    border-top: none;
    border-radius: 0 0 8px 8px;
  }

  .about-page :global(h3 + ul li) {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.8;
    padding-left: 0.75rem;
    position: relative;
  }

  .about-page :global(h3 + ul li::before) {
    content: "•";
    position: absolute;
    left: 0;
    color: var(--color-muted);
  }

  .about-page :global(h3 + ul li strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  /* Connect section links — styled as buttons */
  .about-page :global(h2:last-of-type + ul) {
    list-style: none;
    padding: 0;
    display: flex;
    gap: 1rem;
    border: none;
    background: none;
    border-radius: 0;
  }

  .about-page :global(h2:last-of-type + ul li) {
    padding: 0;
    font-size: 0.9rem;
  }

  .about-page :global(h2:last-of-type + ul li::before) {
    content: none;
  }

  .about-page :global(h2:last-of-type + ul li a) {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.2s, color 0.2s;
  }

  .about-page :global(h2:last-of-type + ul li a:hover) {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  /* Regular links */
  .about-page :global(a) {
    color: var(--color-accent);
    text-decoration: none;
  }

  .about-page :global(a:hover) {
    text-decoration: underline;
  }
</style>
