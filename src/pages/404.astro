---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist." lang="en">
  <div class="not-found">
    <h1>404</h1>
    <p>The page you're looking for doesn't exist.</p>
    <a href="/en/">Go to homepage &rarr;</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 4rem 0;
  }

  .not-found h1 {
    font-size: 4rem;
    color: var(--color-muted);
    margin-bottom: 0.5rem;
  }

  .not-found p {
    font-size: 1.1rem;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }
</style>
