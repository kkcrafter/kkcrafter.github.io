---
import type { Lang } from '../i18n/ui';

interface Props {
  date: Date;
  lang?: Lang;
}

const { date, lang = 'en' } = Astro.props;

const localeMap: Record<string, string> = {
  en: 'en-GB',
  de: 'de-DE',
  zh: 'zh-TW',
};

const formatted = date.toLocaleDateString(localeMap[lang] ?? 'en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<time datetime={date.toISOString()}>{formatted}</time>
