---
import FormattedDate from './FormattedDate.astro';
import { type Lang } from '../i18n/ui';
import { getTagLabel } from '../i18n/tags';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  lang: Lang;
  href: string;
  searchSlug?: string;
  variant?: 'list' | 'card';
}

const { title, description, pubDate, tags, lang, href, searchSlug, variant = 'list' } = Astro.props;
---

<article class:list={['post-card', { 'post-card--card': variant === 'card' }]} data-search-slug={searchSlug}>
  <a href={href} class="post-card__link">
    <h3 class="post-card__title">{title}</h3>
  </a>
  <div class="post-card__meta">
    <FormattedDate date={pubDate} lang={lang} />
  </div>
  <p class="post-card__desc">{description}</p>
  {tags.length > 0 && (
    <div class="post-card__tags">
      {tags.map((tag) => (
        <a href={`/${lang}/blog/tag/${tag}/`} class="tag">
          {getTagLabel(tag, lang)}
        </a>
      ))}
    </div>
  )}
</article>

<style>
  .post-card {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-card:last-child {
    border-bottom: none;
  }

  .post-card__link {
    text-decoration: none;
  }

  .post-card__title {
    font-size: 1.2rem;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }

  .post-card__link:hover .post-card__title {
    color: var(--color-accent);
  }

  .post-card__meta {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin-bottom: 0.4rem;
  }

  .post-card__desc {
    font-size: 0.9rem;
    color: var(--color-muted);
    margin-bottom: 0.5rem;
  }

  .post-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    display: inline-block;
    font-size: 0.7rem;
    padding: 0.15em 0.5em;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-muted);
    text-decoration: none;
  }

  .tag:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    text-decoration: none;
  }

  /* --- Card variant (for landing page grid) --- */
  .post-card--card {
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background-color: var(--color-surface);
    transition: border-color 0.15s ease;
  }

  .post-card--card:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .post-card--card:hover {
    border-color: var(--color-accent);
  }
</style>
