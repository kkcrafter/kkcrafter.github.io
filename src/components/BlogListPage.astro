---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from './PostCard.astro';
import { t, type Lang } from '../i18n/ui';
import { getTagLabel } from '../i18n/tags';
import { getCollection } from 'astro:content';

interface Props {
  lang: Lang;
  activeTag?: string;
}

const { lang, activeTag } = Astro.props;

// Get published posts for this language, sorted by date descending
const allPosts = (
  await getCollection('blog', ({ data }) => data.lang === lang && !data.draft)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Collect all unique tags from these posts
const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags))].sort();

// Filter posts by tag if one is active
const posts = activeTag
  ? allPosts.filter((post) => post.data.tags.includes(activeTag))
  : allPosts;

const pageTitle = activeTag
  ? `${getTagLabel(activeTag, lang)} | ${t(lang, 'blog.title')}`
  : t(lang, 'blog.title');
---

<BaseLayout
  title={`${pageTitle} | ${t(lang, 'site.title')}`}
  description={t(lang, 'blog.description')}
  lang={lang}
>
  <h1>{t(lang, 'blog.title')}</h1>

  {allTags.length > 0 && (
    <nav class="tag-filter" aria-label="Filter by tag">
      <a
        href={`/${lang}/blog/`}
        class:list={['tag-filter__btn', { active: !activeTag }]}
      >
        {t(lang, 'blog.all')}
      </a>
      {allTags.map((tag) => (
        <a
          href={`/${lang}/blog/tag/${tag}/`}
          class:list={['tag-filter__btn', { active: activeTag === tag }]}
        >
          {getTagLabel(tag, lang)}
        </a>
      ))}
    </nav>
  )}

  <div class="post-list">
    {posts.length > 0 ? (
      posts.map((post) => {
        const slug = post.id.split('/').slice(1).join('/');
        return (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            lang={lang}
            href={`/${lang}/blog/${slug}/`}
          />
        );
      })
    ) : (
      <p class="no-posts">{t(lang, 'blog.noPosts')}</p>
    )}
  </div>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 1rem;
  }

  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .tag-filter__btn {
    display: inline-block;
    font-size: 0.8rem;
    padding: 0.3em 0.75em;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-muted);
    text-decoration: none;
    transition: all 0.15s ease;
  }

  .tag-filter__btn:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .tag-filter__btn.active {
    color: #fff;
    background-color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .no-posts {
    color: var(--color-muted);
    padding: 2rem 0;
  }
</style>
